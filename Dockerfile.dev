# Dockerfile para desarrollo local con Quartz
FROM node:22-slim

# Metadata
LABEL maintainer="SOLE Colombia"
LABEL description="Desarrollo local de Voltaje con Quartz"

# Instalar dependencias del sistema
RUN apt-get update && apt-get install -y \
    git \
    python3 \
    python3-pip \
    bash \
    curl \
    rsync \
    && rm -rf /var/lib/apt/lists/*

# Crear directorio de trabajo
WORKDIR /workspace

# Copiar solo package.json para aprovechar cache de Docker
COPY quartz/package*.json ./quartz/

# Instalar dependencias de Node
WORKDIR /workspace/quartz
RUN npm ci && npm cache clean --force

# Volver al directorio raíz
WORKDIR /workspace

# Script de inicio que sincroniza contenido
COPY scripts/docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Exponer puerto de desarrollo
EXPOSE 8080

# Directorio de trabajo para ejecutar Quartz
WORKDIR /workspace/quartz

# Comando por defecto: mantener el contenedor vivo hasta que el usuario ejecute scripts manualmente
CMD ["tail", "-f", "/dev/null"]




