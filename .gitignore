!.obsidian/plugins/
!.obsidian/plugins/obsidian-linter/
!.obsidian/plugins/obsidian-linter/data.json

# Vault compartido para el equipo en `content/` (si ese folder se abre como Vault)
!content/.obsidian/
!content/.obsidian/**
